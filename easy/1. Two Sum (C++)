class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> values;

        for (int i = 0; i < nums.size(); i++) {
            int complement = target - nums[i];

            if (values.contains(complement)) {
                return {values[complement], i};
            }

            values[nums[i]] = i;
        }

        return {};
    }
};
