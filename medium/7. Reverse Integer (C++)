class Solution {
public:
    int reverse(int x) {
        string s = to_string(x);
        std::reverse(s.begin(), s.end());
        try {
            int f = std::stoi(s);
            if (x < 0) {
                return -f;
            } else {
                return f;
            }
        } catch (const std::out_of_range& e) {
            return 0;
        }
    }
};
