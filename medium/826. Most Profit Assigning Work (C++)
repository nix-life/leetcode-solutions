class Solution {
public:
    int maxProfitAssignment(vector<int>& difficulty, vector<int>& profit, vector<int>& worker) {
        int total = 0;
        int n = profit.size();
        vector<pair<int, int>> x(n);

        for (int i = 0; i < n; i++) {
            x[i] = {difficulty[i], profit[i]};
        }

        sort(x.begin(), x.end());
        sort(worker.begin(), worker.end());
        
        int j = 0;
        int maxProfit = 0;
        for (int i = 0; i < worker.size(); i++) {
            while (j < n && worker[i] >= x[j].first) {
                maxProfit = max(maxProfit, x[j].second);
                j++;
            }
            total+=maxProfit;
        }

        return total;
    }
};
