class Solution {
public:
    int findMin(vector<int>& nums) {
        int left = 0;
        int right = nums.size()-1;
        int minimum = -1;

        while (left <= right) {
            int mid = (left + right) / 2;

            if (nums[mid] <= nums[nums.size()-1]) {
                minimum = nums[mid];
                right = mid - 1;
            } else {
                left = mid + 1;
            }
        }

        return minimum;
    }
};
